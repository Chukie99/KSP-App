{
  "name": "koperasi-simpan-pinjam",
  "version": "1.0.0",
  "description": "Aplikasi Desktop Koperasi Simpan Pinjam",
  "main": "dist-electron/main/index.js",
  "author": "Chukie99",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:win": "vite build && electron-builder --win dir --config.win.sign=null",
    "build:portable": "vite build && electron-builder --win portable --config.win.sign=null",
    "start": "vite --port 5173"
  },
  "build": {
    "appId": "com.ksp.simpinjam",
    "productName": "KSP Simpan Pinjam",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "icon": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KSP Simpan Pinjam"
    },
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": ["**/*"]
      }
    ],
    "extraFiles": [
      {
        "from": "dist-electron/main/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ]
  },
  "dependencies": {
    "sql.js": "^1.10.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
